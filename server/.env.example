DATABASE_URL="file:./axeriva.db"
JWT_SECRET="change-me-to-a-long-random-secret"

# Stripe
STRIPE_PUBLISHABLE_KEY=""
STRIPE_SECRET_KEY=""
STRIPE_PRICE_ID=""
