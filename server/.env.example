# Axeriva backend environment — copy to server/.env and fill in.
# Validation: DATABASE_URL and JWT_SECRET are required in every environment;
# with NODE_ENV=production ALL variables marked (prod: required) must be set
# or the server exits at startup. See docs/environment.md.

# "development" (default) or "production"
NODE_ENV="development"

# API port (default: 5000)
PORT=5000

# SQLite database file. Production: point inside the persistent disk mount,
# e.g. file:/var/data/axeriva.db
DATABASE_URL="file:./axeriva.db"

# Long random string used to sign JWTs — required everywhere.
JWT_SECRET="change-me-to-a-long-random-secret"

# Frontend origin — used for CORS and for links in emails / Stripe redirects.
# (prod: required) Unset locally = allow-all CORS + http://localhost:5173 links.
APP_URL="http://localhost:5173"

# Absolute path to a persistent disk mount for uploaded project attachments
# (see middleware/upload.middleware.ts). (prod: required) Leave unset locally;
# defaults to ./uploads under the server working directory.
# UPLOAD_ROOT="/var/data/uploads"

# Stripe — (prod: required). Leave unset locally to disable billing routes
# (they fail with a clear error instead of silently using a fake key).
STRIPE_SECRET_KEY=""
STRIPE_PRICE_ID=""
STRIPE_WEBHOOK_SECRET=""

# Currently UNUSED by the code (no frontend Stripe.js integration yet) —
# kept only as a placeholder for a future client-side Stripe integration.
STRIPE_PUBLISHABLE_KEY=""

# Resend (email) — (prod: required). Leave RESEND_API_KEY unset locally to
# use MockEmailService (emails are logged to the console, not sent).
RESEND_API_KEY=""
RESEND_FROM_EMAIL="Axeriva <noreply@axeriva.com>"

# Used only by `npm run seed:developer` when no CLI args are given.
# DEVELOPER_EMAIL="admin@example.com"
# DEVELOPER_PASSWORD="change-me"
