# Axeriva frontend environment — copy to .env (repo root) if needed.
# All backend variables live in server/.env (see server/.env.example).

# Backend API URL the frontend talks to. Read at BUILD time by Vite — set
# this in the production build environment (e.g. Render Static Site env
# vars) to the deployed backend URL. Leave unset locally to use
# http://localhost:5000 (see src/services/api.ts).
# VITE_API_URL="https://api.axeriva.com"
